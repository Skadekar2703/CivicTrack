<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/mapHeadline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Issue Map"
        android:textColor="@color/civic_primary"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/mapSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="16dp"
        android:text="Explore nearby reports and tap pins to view live issue details."
        android:textColor="@color/civic_muted"
        android:textSize="15sp" />

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <org.osmdroid.views.MapView
            android:id="@+id/osmMapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/civic_surface_low" />

        <TextView
            android:id="@+id/noIssuesText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@drawable/bg_map_hint"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:text="No reports yet"
            android:textColor="@color/civic_primary"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|bottom"
            android:layout_margin="16dp"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/locationButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_map_fab"
                android:contentDescription="Current location"
                android:padding="14dp"
                android:src="@drawable/ic_my_location"
                android:tint="@color/civic_primary" />

            <ImageButton
                android:id="@+id/refreshButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_map_fab"
                android:contentDescription="Refresh issues"
                android:padding="14dp"
                android:src="@drawable/ic_refresh"
                android:tint="@color/civic_primary" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mapIssueSheet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_margin="16dp"
            app:cardBackgroundColor="@color/civic_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="10dp"
            app:layout_behavior="@string/bottom_sheet_behavior"
            app:strokeColor="@color/civic_outline"
            app:strokeWidth="1dp">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="420dp"
                android:fillViewport="true"
                android:overScrollMode="ifContentScrolls">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/mapIssueImage"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/issue_pothole_lovable" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:id="@+id/mapIssueTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/civic_ink"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/mapIssueDescription"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textColor="@color/civic_muted"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/mapIssueLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textColor="@color/civic_muted"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <View
                                android:id="@+id/mapIssueStatusDot"
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:background="@drawable/bg_notification_dot" />

                            <TextView
                                android:id="@+id/mapIssueStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_map_status"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="8dp"
                                android:textColor="@color/civic_primary"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/mapIssueType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:textColor="@color/civic_primary"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </com.google.android.material.card.MaterialCardView>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</LinearLayout>
